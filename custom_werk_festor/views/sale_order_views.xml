<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_views_inherit_dataforge" model="ir.ui.view">
        <field name="name">sale.order.view.inherit.dataforge</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_term_id']" position="after">
				<field name="x_studio_aantal_personen" />
                <field name="df_startDatum" widget="datarange" options="{&quot;start_date_field&quot;:&quot;df_startDatum&quot;,&quot;end_date_field&quot;:&quot;df_eindDatum&quot;}"/>
                <field name="df_eindDatum" invisible="1"></field>
            </xpath>
            <xpath expr="//field[@name='order_line']//list//field[@name='product_template_id']" position="after">
                <button name="action_view_forecast"
                        type="object"
                        icon="fa-line-chart"
                        title="Prognose"
                        class="btn-link"
                        invisible="not product_template_id"/>
            </xpath>
        </field>
    </record>

    <!-- Remove stale view record from previous upgrade attempt -->
    <delete model="ir.ui.view" search="[('key', '=', 'custom_werk_festor.sale_order_line_pickings_button')]"/>

    <record id="rental_order_form_inherit_verifieer" model="ir.ui.view">
        <field name="name">rental.order.form.inherit.verifieer</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_renting.rental_order_primary_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_verify_rental_availability"
                        string="Verifieer"
                        type="object"
                        class="btn-secondary"/>
            </xpath>
        </field>
    </record>
</odoo>
