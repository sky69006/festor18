<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="delivery_slip_custom_dates" inherit_id="stock.report_delivery_document">
        <!-- Replace the Verzenddatum (verzendingsdatum) block with event date and current date -->
        <xpath expr="//div[@name='div_sched_date']" position="replace">
            <div class="col col-3 mw-100 mb-2" name="div_event_date">
                <strong>Datum event:</strong>
                <div t-if="o.sale_id and o.sale_id.df_startDatum"
                     t-out="o.sale_id.df_startDatum"
                     t-options='{"widget": "datetime", "format": "dd/MM/yyyy HH:mm"}'
                     class="m-0"/>
                <div t-else="" class="m-0">-</div>
            </div>
            <div class="col col-3 mw-100 mb-2" name="div_print_date">
                <strong>Afdrukdatum:</strong>
                <div t-out="datetime.datetime.now()"
                     t-options='{"widget": "datetime", "format": "dd/MM/yyyy HH:mm"}'
                     class="m-0"/>
            </div>
        </xpath>
    </template>
</odoo>
